## =========================
## Proveedor LLM (completa luego)
## =========================
# Deja vacio hasta que decidas cargar saldo.
OPENAI_API_KEY=
# Alternativa Azure (opcional)
AZURE_ENDPOINTS=
AZURE_API_KEYS=

# Si quieres usar Anthropic en AWS Bedrock, completa estas variables:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_MODEL_ID_MAPPING=claude-sonnet-4:anthropic.claude-sonnet-4-20250514-v1:0

## =========================
## Core de Tero
## =========================
# URL del frontend/backend local de Tero
FRONTEND_URL=http://localhost:8000
OPENID_URL=http://localhost:8080/realms/tero

## =========================
## Browser tool (Playwright MCP)
## =========================
# Ejecucion de pruebas web por agente
BROWSER_TOOL_PLAYWRIGHT_MCP_URL=http://localhost:8931/mcp
BROWSER_TOOL_PLAYWRIGHT_OUTPUT_DIR=var/playwright-output

## =========================
## Modelos y costo
## =========================
# Opcion economica para iniciar cuando cargues key:
AGENT_DEFAULT_MODEL=gpt-5-mini
INTERNAL_GENERATOR_MODEL=gpt-5-mini
INTERNAL_EVALUATOR_MODEL=gpt-5-mini
AGENT_BASIC_MODELS=gpt-5-mini,gpt-5-nano
# Limite mensual por usuario en USD (proteccion de costo)
MONTHLY_USD_LIMIT_DEFAULT=3
